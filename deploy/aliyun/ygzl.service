[Unit]
Description=YGZL Digital Twin Flask API
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/ygzl_2026_1/backend
EnvironmentFile=/opt/ygzl_2026_1/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/ygzl_2026_1/.venv/bin/gunicorn -w 2 -k gthread --threads 4 -b 127.0.0.1:5000 --timeout 120 wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
